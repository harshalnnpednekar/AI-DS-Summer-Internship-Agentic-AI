# Database Connection String
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/event_notification

# Security & Sessions
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_ALGORITHM=HS256

# Application Configuration
DEBUG=True
APP_NAME=EduAgent
PROJECT_NAME="College Event Notification System"
VERSION=1.0.0

# CORS Allowed Origins (Comma separated or json array)
ALLOWED_ORIGINS=["*"]

# Email Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=True
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME="EduAgent Notifications"
